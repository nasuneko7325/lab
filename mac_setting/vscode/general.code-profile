    "extensions": "[{\"identifier\":{\"id\":\"bmewburn.vscode-intelephense-client\",\"uuid\":\"ffda6552-0ad5-431b-a4fa-0905a7e4f3f0\"},\"displayName\":\"PHP Intelephense\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"bradlc.vscode-tailwindcss\",\"uuid\":\"4db62a7c-7d70-419c-96d2-6c3a4dc77ea5\"},\"displayName\":\"Tailwind CSS IntelliSense\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"davidanson.vscode-markdownlint\",\"uuid\":\"daf8b44d-8aae-4da2-80c5-1f770219f643\"},\"displayName\":\"markdownlint\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"ms-azuretools.vscode-containers\",\"uuid\":\"2cd1d691-3d69-4d2d-ae39-fda4bc4cfd3d\"},\"displayName\":\"Container Tools\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"ms-azuretools.vscode-docker\",\"uuid\":\"0479fc1c-3d67-49f9-b087-fb9069afe48f\"},\"displayName\":\"Docker\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"ms-ceintl.vscode-language-pack-ja\",\"uuid\":\"077515fe-1509-49c0-9dcc-5511b41682fc\"},\"displayName\":\"Japanese Language Pack for Visual Studio Code\",\"applicationScoped\":true}]",
    "keybindings": "{\"keybindings\":\"// 既定値を上書きするには、このファイル内にキー バインドを挿入します\\n[\\n    {\\n        \\\"key\\\": \\\"ctrl+i\\\",\\n        \\\"command\\\": \\\"editor.action.triggerSuggest\\\",\\n        \\\"when\\\": \\\"editorHasCompletionItemProvider && textInputFocus && !editorReadonly && !suggestWidgetVisible\\\"\\n    }\\n]\\n\",\"platform\":1}",
    "name": "general",
    "settings": "{\"settings\":\"{\\n    \\\"editor.quickSuggestions\\\": {\\n        \\\"strings\\\": \\\"on\\\"\\n    },\\n    \\\"editor.fontFamily\\\": \\\"'SauceCodePro Nerd Font Mono', Menlo, Monaco, 'Courier New', monospace\\\",\\n    \\\"editor.formatOnSave\\\": true,\\n    \\\"editor.renderWhitespace\\\": \\\"boundary\\\",\\n    \\\"editor.wordWrap\\\": \\\"on\\\",\\n    \\\"files.associations\\\": {\\n        \\\"*.css\\\": \\\"tailwindcss\\\"\\n    },\\n    \\\"files.insertFinalNewline\\\": true,\\n    \\\"files.trimFinalNewlines\\\": true,\\n    \\\"files.trimTrailingWhitespace\\\": true,\\n    \\\"terminal.integrated.lineHeight\\\": 1.4,\\n    \\\"window.zoomLevel\\\": 1,\\n    \\\"workbench.editor.enablePreview\\\": false,\\n    \\\"workbench.editor.pinnedTabsOnSeparateRow\\\": true,\\n    \\\"workbench.editor.tabSizing\\\": \\\"shrink\\\",\\n    \\\"workbench.startupEditor\\\": \\\"none\\\",\\n    \\\"workbench.tree.indent\\\": 28,\\n    \\\"workbench.tree.renderIndentGuides\\\": \\\"always\\\",\\n    \\\"github.copilot.nextEditSuggestions.enabled\\\": true,\\n    \\\"workbench.editor.closeEmptyGroups\\\": false,\\n    \\\"github.copilot.enable\\\": {\\n        \\\"*\\\": false,\\n        \\\"plaintext\\\": false,\\n        \\\"markdown\\\": false,\\n        \\\"scminput\\\": false,\\n        \\\"php\\\": false,\\n        \\\"dockercompose\\\": false\\n    },\\n    \\\"diffEditor.renderSideBySide\\\": true\\n}\\n\"}"
}
